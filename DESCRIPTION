Package: poissonsuperlearner
Title: Poisson Super Learner
Version: 0.1.0
Authors@R: 
    c(person(given="Gabriele", family="Pittarello", email ="gabriele.pittarello@sund.ku.dk", role = c("aut", "cre")),
